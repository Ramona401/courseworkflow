// ==================== extractWriteStageFromNatural 测试 ====================

// TestExtractWriteStage_WithFullLesson 包含完整教案的write阶段回复
func TestExtractWriteStage_WithFullLesson(t *testing.T) {
content := `好的，以下是完整的教案：

# 一元一次方程教学设计

## 教学目标
1. 理解一元一次方程的定义
2. 掌握基本求解方法

## 教学重难点
重点：方程的基本解法
难点：移项变号的理解

## 教学准备
PPT课件、练习题

## 教学方法
讲授法、合作探究法

## 教学过程

### 一、导入新课（5分钟）
通过生活情境引入方程概念，激发学生兴趣。

### 二、探究新知（20分钟）
引导学生发现方程的本质特征，通过具体实例推导解法。

### 三、巩固练习（15分钟）
分层练习设计，基础题与提高题结合。

### 四、课堂小结（5分钟）
总结本课重点知识，回顾方程定义和解法步骤。

## 作业布置
1. 课本第42页练习1-5
2. 思考题一道

## 板书设计
一元一次方程
定义 → 解法 → 应用
` + strings.Repeat("这是补充内容确保教案长度足够。\n", 80)

structured, narrative, hasContent := extractWriteStageFromNatural(content)
if !hasContent {
t.Error("包含完整教案应返回hasContent=true")
}
if structured == "" || structured == "{}" {
t.Error("structured不应为空")
}
// structured应包含content_markdown
var data map[string]interface{}
if err := json.Unmarshal([]byte(structured), &data); err != nil {
t.Fatalf("structured应为合法JSON: %v", err)
}
if _, ok := data["content_markdown"]; !ok {
t.Error("应包含content_markdown字段")
}
_ = narrative // narrative可能为空或有值，不强制断言
}

// TestExtractWriteStage_ShortContent 内容太短不构成教案
func TestExtractWriteStage_ShortContent(t *testing.T) {
content := "好的，我来帮你写教案。首先确认一下课题。"
structured, _, hasContent := extractWriteStageFromNatural(content)
// 短内容没有教案标记，应走fallback
if hasContent && structured != "{}" {
var data map[string]interface{}
if err := json.Unmarshal([]byte(structured), &data); err == nil {
if _, ok := data["content_markdown"]; ok {
// 有content_markdown说明检测到了教案，但内容太短
t.Logf("短内容也检测到教案（可能是宽松匹配），structured长度=%d", len(structured))
}
}
}
// 不管hasContent值，不应panic
t.Logf("短内容: hasContent=%v, structured长度=%d", hasContent, len(structured))
}

// TestExtractWriteStage_Empty 空内容
func TestExtractWriteStage_Empty(t *testing.T) {
structured, narrative, hasContent := extractWriteStageFromNatural("")
if hasContent {
t.Error("空内容应返回false")
}
if structured != "{}" {
t.Errorf("空内容structured应为'{}'，实际%q", structured)
}
if narrative != "" {
t.Errorf("空内容narrative应为空，实际%q", narrative)
}
}

// ==================== extractReviewStageFromNatural 测试 ====================

// TestExtractReviewStage_FullReview 完整评审报告
func TestExtractReviewStage_FullReview(t *testing.T) {
content := `# 教案评审报告

## 评审维度

| 维度 | 评分 | 点评 |
|------|------|------|
| T1 教学目标 | 8.5 | 目标明确，层次分明 |
| T2 教学内容 | 7.0 | 内容基本合理 |
| T3 教学方法 | 8.0 | 方法多样 |
| T4 教学评价 | 7.5 | 评价较为全面 |

## 做得好的点

**1. 教学目标设定清晰**
三维目标覆盖完整，可观察可评估。

**2. 活动设计丰富**
探究活动和小组合作结合良好。

## 改进建议

**1. 导入环节时间偏长**
建议将导入从10分钟缩短到5分钟。

**2. 缺少形成性评价**
建议增加课堂即时检测环节。

## 总评

综合评分：7.8/10

整体来看，这是一份结构完整的教案，教学目标明确，但在时间分配和评价方式上还有提升空间。
`
structured, narrative, hasContent := extractReviewStageFromNatural(content)
if !hasContent {
t.Error("完整评审报告应返回hasContent=true")
}
if structured == "" || structured == "{}" {
t.Error("structured不应为空")
}
var data map[string]interface{}
if err := json.Unmarshal([]byte(structured), &data); err != nil {
t.Fatalf("structured应为合法JSON: %v", err)
}
// 验证总分
if score, ok := data["total_score"]; ok {
if s, ok := score.(float64); !ok || s <= 0 {
t.Errorf("total_score应>0，实际%v", score)
}
} else {
t.Error("应包含total_score")
}
// 验证维度
if dims, ok := data["dimensions"]; ok {
if dimArr, ok := dims.([]interface{}); ok {
if len(dimArr) < 2 {
t.Errorf("应至少有2个维度，实际%d", len(dimArr))
}
}
}
if narrative == "" {
t.Log("narrative为空（可能正常，评审全在structured中）")
}
}

