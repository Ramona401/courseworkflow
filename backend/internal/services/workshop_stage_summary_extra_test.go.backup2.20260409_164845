// ==================== GenerateStageSummary 更多边界场景 ====================

// TestGenerateStageSummary_ReviseStage revise阶段
func TestGenerateStageSummary_ReviseStage(t *testing.T) {
msgs := []*models.ConversationMessage{
makeUserMsg("按照评审建议修改"),
makeAIMsg("好的，我已根据建议进行了修订。"),
